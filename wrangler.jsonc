{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "see-infra",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-09",
  "workers_dev": false,
  "build": {
    "command": "npm run generate:destinations",
    "watch_dir": ["src", "scripts"]
  },
  "routes": [
    {
      "pattern": "see.etseq.co",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
