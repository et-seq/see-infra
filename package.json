{
  "name": "see-infra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "CC-BY-NC-SA-4.0",
  "description": "Cloudflare Worker redirector for see.etseq.co legal reference shortcuts.",
  "scripts": {
    "generate:destinations": "node scripts/generate-destination-manifest.mjs",
    "predev": "npm run generate:destinations",
    "dev": "wrangler dev",
    "predeploy": "npm run generate:destinations",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "pretypecheck": "npm run generate:destinations",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run generate:destinations",
    "test": "vitest run",
    "check": "npm run typecheck && npm test"
  },
  "dependencies": {
    "hono": "^4.7.11"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.1.4",
    "wrangler": "^4.14.4"
  }
}
